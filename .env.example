# Example environment variables for local development.
# Copy this file to .env and fill in your secret values.
# Do not commit .env to source control.

BOT_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
OLLAMA_CLOUD_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
TELEGRAM_AI_OWNER_CHAT_ID=
TELEGRAM_ALWAYS_LISTEN_CHAT_IDS=

DA_MODEL=
DA_AGENT_ID=default
DA_AUTO_APPROVE=1
DA_ENABLE_SHELL=0
USE_SANDBOX=none

MEM0_API_KEY=
ASTRA_DB_API_KEY=
ASTRA_DB_ENDPOINT=
ASTRA_DB_KEYSPACE=

PUBLIC_URL=

# ElevenLabs TTS (optional)
ELEVENLABS_API_KEY=
ELEVEN_LABS_API_KEY=
ELEVEN_LABS_VOICE_ID=
ELEVEN_LABS_VOICE=
ELEVEN_LABS_MODEL=eleven_turbo_v2

TELEGRAM_USE_WEBHOOK=1
TELEGRAM_SET_WEBHOOK=0
TELEGRAM_WEBHOOK_SECRET=telegram-webhook
PORT=10000

# Set TELEGRAM_USE_WEBHOOK=0 to enable polling mode instead of webhook mode.
# Webhook mode is preferred to avoid automatic polling conflicts.
